:- module(hnf_repeated_var_within_head, [eq/3, threeway/4, type(pat/0)]).
:- chr_constraint eq/3, threeway/4.
:- chr_type pat ---> a ; b ; p(any, any).

% Repeated var within a single head: eq(X, X, R). Implicit equality.
eq(X, X, R) <=> R = term(same).
eq(_, _, R) <=> R = term(different).

% Three-arg variant.
threeway(X, X, X, R) <=> R = term(all_equal).
threeway(X, X, _, R) <=> R = term(first_two).
threeway(_, X, X, R) <=> R = term(last_two).
threeway(_, _, _, R) <=> R = term(all_different).
