:- module(hnf_literal_in_head, [tag/2, type(pat/0)]).
:- chr_constraint tag/2.
:- chr_type pat ---> foo ; bar ; p(any, any) ; a ; b ; c.

% Literal head args of every kind: int, float, atom, string, empty list, compound.
tag(0, R)         <=> R = term(zero).
tag(42, R)        <=> R = term(answer).
tag(1.5, R)       <=> R = term(one_half).
tag(0.0, R)       <=> R = term(float_zero).
tag(foo, R)       <=> R = term(foo_atom).
tag("hi", R)      <=> R = term(hi_string).
tag([], R)        <=> R = term(empty_list).
tag(p(a, b), R)   <=> R = term(pair_ab).
tag(_, R)         <=> R = term(catchall).
