:- module(bounded_requiring_on_multi_sig, [result/1]).
:- use_module(library(prelude)).

:- chr_constraint result(int).

:- function (gt(int, int) -> bool), (gt(float, float) -> bool).
gt(X, Y) -> X > Y.

% Forbidden: requiring on the comma-separated multi-signature form.
% The parser rejects this as RequiringOnMultiSig (YCHR-15005).
:- function
    (pick(int, int) -> int requiring gt(int, int) -> bool),
    (pick(float, float) -> float).

pick(X, _) -> X.

result(R) <=> R is pick(1, 2).
