:- module(but, [test/1]).
:- chr_constraint test/1.

% Typo inside an evaluating position: YY is not introduced by the
% '=' because it sits inside a function-call argument; the compiler
% must reject it as unbound (YCHR-40002) rather than silently
% allocate a fresh logical variable.
:- function double/1.
double(X) -> X * 2.

test(R) <=> Y is 10, R = double(YY).
