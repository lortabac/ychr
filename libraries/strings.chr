:- module(strings, [string_concat/3, string_length/2, string_upper/2, string_lower/2]).

:- chr_constraint string_concat/3, string_length/2, string_upper/2, string_lower/2.

string_concat(X, Y, R) <=> R := string_concat(X, Y).
string_length(S, R) <=> R := string_length(S).
string_upper(S, R) <=> R := string_upper(S).
string_lower(S, R) <=> R := string_lower(S).
